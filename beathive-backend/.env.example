# Beathive Backend Environment Example
# Copy this file to .env, then fill it with your own credentials.
# Do not commit the filled .env file.

# App runtime
# NODE_ENV: development or production.
NODE_ENV=
# PORT: backend API port.
PORT=
# FRONTEND_URL: frontend web URL allowed to access this API.
FRONTEND_URL=
# APP_URL: public backend/API base URL.
APP_URL=
# ADMIN_URL: admin dashboard URL.
ADMIN_URL=

# Database and cache
# DATABASE_URL: PostgreSQL connection string.
DATABASE_URL=
# REDIS_URL: Redis connection string.
REDIS_URL=

# Auth and tokens
# JWT_SECRET: long random secret for access tokens.
JWT_SECRET=
# JWT_EXPIRES_IN: access token lifetime, for example 7d.
JWT_EXPIRES_IN=
# JWT_REFRESH_SECRET: different long random secret for refresh tokens.
JWT_REFRESH_SECRET=
# JWT_REFRESH_EXPIRES_IN: refresh token lifetime, for example 30d.
JWT_REFRESH_EXPIRES_IN=
# JWT_RESET_SECRET: different long random secret for password reset tokens.
JWT_RESET_SECRET=

# Google OAuth API
# GOOGLE_CLIENT_ID: OAuth client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET: OAuth client secret from Google Cloud Console.
GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL: backend callback URL registered in Google OAuth.
GOOGLE_CALLBACK_URL=

# Storage API: AWS S3 or compatible storage
# USE_LOCAL_STORAGE: true to store uploads locally instead of S3.
USE_LOCAL_STORAGE=
# AWS_REGION: bucket region, for example ap-southeast-1.
AWS_REGION=
# AWS_ACCESS_KEY_ID: storage access key.
AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY: storage secret key.
AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_PRIVATE: private bucket for original downloadable files.
AWS_S3_BUCKET_PRIVATE=
# AWS_S3_BUCKET_PUBLIC: public bucket for previews/assets.
AWS_S3_BUCKET_PUBLIC=
# AWS_CLOUDFRONT_DOMAIN: CDN domain for public files.
AWS_CLOUDFRONT_DOMAIN=

# Payment API: Midtrans
# MIDTRANS_SERVER_KEY: private server key from Midtrans dashboard.
MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY: public client key from Midtrans dashboard.
MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION: true for production, false for sandbox.
MIDTRANS_IS_PRODUCTION=
# MIDTRANS_MERCHANT_ID: merchant ID from Midtrans dashboard.
MIDTRANS_MERCHANT_ID=
# MIDTRANS_WEBHOOK_SECRET: optional webhook verification secret if used.
MIDTRANS_WEBHOOK_SECRET=

# Bank account verification API: Flip.id
# FLIP_SECRET_KEY: Flip.id API secret key.
FLIP_SECRET_KEY=
# FLIP_IS_PRODUCTION: true for production, false for sandbox.
FLIP_IS_PRODUCTION=

# Email API: SMTP or Mailgun
# SMTP_HOST: SMTP server host, for example smtp.gmail.com.
SMTP_HOST=
# SMTP_PORT: SMTP server port, usually 587 or 465.
SMTP_PORT=
# SMTP_USER: SMTP username/email.
SMTP_USER=
# SMTP_PASS: SMTP password/app password.
SMTP_PASS=
# MAILGUN_API_KEY: Mailgun API key if using Mailgun.
MAILGUN_API_KEY=
# MAILGUN_DOMAIN: Mailgun sending domain.
MAILGUN_DOMAIN=
# EMAIL_FROM: sender email shown to users.
EMAIL_FROM=