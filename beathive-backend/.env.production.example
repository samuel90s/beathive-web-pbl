# Beathive Backend Production Environment Example
# Copy this file to .env on production, then fill it with real production values.
# Do not commit the filled .env file.

# App runtime
NODE_ENV=
PORT=
FRONTEND_URL=
APP_URL=
ADMIN_URL=

# Database and cache
DATABASE_URL=
REDIS_URL=

# Auth and tokens
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=
JWT_RESET_SECRET=

# Google OAuth API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Storage API: use local storage or fill AWS S3 values.
USE_LOCAL_STORAGE=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_PRIVATE=
AWS_S3_BUCKET_PUBLIC=
AWS_CLOUDFRONT_DOMAIN=

# Payment API: Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=
MIDTRANS_MERCHANT_ID=
MIDTRANS_WEBHOOK_SECRET=

# Bank account verification API: Flip.id
FLIP_SECRET_KEY=
FLIP_IS_PRODUCTION=

# Email API: SMTP or Mailgun
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
EMAIL_FROM=
