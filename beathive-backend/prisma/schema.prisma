// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?  // null kalau login via OAuth
  avatarUrl    String?
  bio          String?
  bankName        String?
  bankAccount     String?
  bankAccountName String?
  // TODO (BE-03): migrate to Prisma Enum `enum UserRole { USER ADMIN }` to get type safety and prevent typos
  role         String   @default("USER") // "USER" | "ADMIN"
  provider     String   @default("email") // "email" | "google"
  providerId   String?  // ID dari Google OAuth
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  totpSecret         String?
  isTwoFactorEnabled Boolean  @default(false)

  emailVerified      Boolean  @default(true)  // true untuk user lama, false untuk register baru
  emailVerifyToken   String?
  refreshTokenHash   String?
  refreshTokenUpdatedAt DateTime?

  subscription   Subscription?
  orders         Order[]
  downloads      Download[]
  wishlists      Wishlist[]
  uploadedAssets AudioAsset[] @relation("AuthorAssets")
  wallet         CreatorWallet?
  ratings        Rating[]
  notifications  Notification[]

  @@map("users")
}

// ─── Plans ───────────────────────────────────────────────

model Plan {
  id               String   @id @default(uuid())
  name             String   // "Free", "Pro", "Business"
  slug             String   @unique // "free", "pro", "business"
  priceMonthly     Int      @default(0) // dalam Rupiah
  priceYearly      Int      @default(0)
  downloadLimit    Int      @default(5)  // -1 = unlimited
  commercialLicense Boolean @default(false)
  unlimited        Boolean  @default(false)
  createdAt        DateTime @default(now())

  subscriptions Subscription[]

  @@map("plans")
}

// ─── Subscriptions ───────────────────────────────────────

model Subscription {
  id               String             @id @default(uuid())
  userId           String             @unique
  planId           String
  status           SubscriptionStatus @default(ACTIVE)
  billingCycle     BillingCycle       @default(MONTHLY)
  gatewaySubId     String?            // ID subscription di Midtrans/Xendit
  currentPeriodEnd DateTime
  cancelledAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user   User @relation(fields: [userId], references: [id])
  plan   Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE    // gagal bayar, masih grace period
  SUSPENDED   // sudah di-suspend
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// ─── Categories & Tags ───────────────────────────────────

model Category {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  icon         String?
  type         String        @default("sfx") // "sfx" | "music"
  audioAssets AudioAsset[]

  @@map("categories")
}

model Tag {
  id           String              @id @default(uuid())
  name         String
  slug         String              @unique
  audioAssets AudioAssetOnTag[]

  @@map("tags")
}

// ─── Sound Effects ───────────────────────────────────────

model AudioAsset {
  id           String      @id @default(uuid())
  assetType    String      @default("SFX") // "SFX" | "MUSIC"
  categoryId   String
  authorId     String?     // null = upload oleh admin, ada = upload oleh author
  title        String
  slug         String      @unique
  description  String?
  fileUrl      String      // path di S3 (private)
  previewUrl   String      // path preview 30s di S3 (public via CDN)
  waveformData Json        // array of bar heights untuk visualizer
  durationMs   Int
  fileSize     Int         // bytes
  format       String      @default("wav") // "wav" | "mp3" | "ogg" | "flac"
  price        Int         @default(0)     // 0 = gratis, dalam Rupiah
  accessLevel  AccessLevel @default(FREE)  // siapa yang bisa download
  licenseType  String      @default("personal") // "personal" | "commercial" | "both"
  isPublished   Boolean     @default(false)
  publishedAt   DateTime?
  // TODO (BE-04): migrate to Prisma Enum for type safety (PENDING|APPROVED|REJECTED|NEEDS_RE_REVIEW)
  reviewStatus  String      @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED" | "NEEDS_RE_REVIEW"
  reviewNote    String?     // alasan reject dari admin
  reviewedAt    DateTime?
  reviewedById  String?     // admin user ID
  bpm          Int?        // beats per minute (music only)
  mood         String?     // "upbeat"|"calm"|"epic"|"sad"|"dark"|"happy"|"neutral"|"tense"
  musicalKey   String?     // "C"|"D"|"Em" etc.
  hasStems     Boolean     @default(false)
  playCount     Int         @default(0)
  downloadCount Int        @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  category   Category           @relation(fields: [categoryId], references: [id])
  author     User?              @relation("AuthorAssets", fields: [authorId], references: [id])
  tags       AudioAssetOnTag[]
  orderItems OrderItem[]
  downloads  Download[]
  wishlists  Wishlist[]
  ratings    Rating[]
  sfxMetadata   SfxMetadata?
  musicMetadata MusicMetadata?
  genres        AudioAssetGenre[]

  @@index([isPublished, categoryId])
  @@index([assetType])
  @@index([authorId])
  @@index([accessLevel])
  @@index([isPublished, accessLevel])
  @@map("audio_assets")
}

model SfxMetadata {
  assetId     String  @id
  subcategory String?

  asset AudioAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("sfx_metadata")
}

model MusicMetadata {
  assetId    String  @id
  bpm        Int?
  mood       String?
  musicalKey String?
  hasStems   Boolean @default(false)

  asset AudioAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([mood])
  @@index([bpm])
  @@map("music_metadata")
}

model Genre {
  id     String       @id @default(uuid())
  name   String
  slug   String       @unique
  assets AudioAssetGenre[]

  @@map("genres")
}

model AudioAssetGenre {
  assetId String
  genreId String

  asset AudioAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  genre Genre       @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([assetId, genreId])
  @@index([genreId])
  @@map("audio_asset_genres")
}

enum AccessLevel {
  FREE       // semua bisa download
  PRO        // butuh plan Pro ke atas
  BUSINESS   // butuh plan Business
  PURCHASE   // hanya bisa dibeli satuan
}

model AudioAssetOnTag {
  audioAssetId String
  tagId         String

  audioAsset AudioAsset @relation(fields: [audioAssetId], references: [id])
  tag        Tag        @relation(fields: [tagId], references: [id])

  @@id([audioAssetId, tagId])
  @@map("audio_asset_tags")
}

// ─── Orders ──────────────────────────────────────────────

model Order {
  id             String      @id @default(uuid())
  userId         String
  totalAmount    Int         // total dalam Rupiah
  status         OrderStatus @default(PENDING)
  gatewayOrderId String?     // ID order di Midtrans/Xendit
  snapToken      String?     // Midtrans Snap token untuk re-open popup
  paidAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
  invoice   Invoice?

  @@index([userId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id            String @id @default(uuid())
  orderId       String
  audioAssetId  String
  priceSnapshot Int    // harga saat transaksi — tidak berubah walau harga SFX diupdate
  licenseType   String // "personal" | "commercial"
  licensePdfUrl String? // URL PDF lisensi setelah generated

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  audioAsset AudioAsset @relation(fields: [audioAssetId], references: [id])

  @@map("order_items")
}

// ─── Invoices ────────────────────────────────────────────

model Invoice {
  id            String   @id @default(uuid())
  orderId       String   @unique
  invoiceNumber String   @unique // e.g. "INV-2024-00001"
  pdfUrl        String?
  issuedAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("invoices")
}

// ─── Downloads ───────────────────────────────────────────

model Download {
  id            String   @id @default(uuid())
  userId        String
  audioAssetId  String
  source        String   // "subscription" | "purchase"
  signedUrl     String?  // signed URL sementara (expire 24 jam)
  expiresAt     DateTime?
  downloadedAt  DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  audioAsset AudioAsset @relation(fields: [audioAssetId], references: [id])

  @@index([userId])
  @@index([audioAssetId])
  @@map("downloads")
}

// ─── Subscription Intents ────────────────────────────────
// Stores pending subscription payment info keyed by Midtrans orderId

model SubscriptionIntent {
  id           String   @id @default(uuid())
  orderId      String   @unique // Midtrans order_id (SUB-xxxxx format)
  userId       String
  planSlug     String
  billingCycle String   // "monthly" | "yearly"
  createdAt    DateTime @default(now())

  @@map("subscription_intents")
}

// ─── Creator Wallet & Earnings ───────────────────────────

model CreatorWallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0) // saldo dalam Rupiah (belum dicairkan)
  totalEarned Int    @default(0) // total lifetime earning
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  earnings CreatorEarning[]
  withdrawals WithdrawalRequest[]

  @@map("creator_wallets")
}

model CreatorEarning {
  id           String   @id @default(uuid())
  walletId     String
  audioAssetId String
  downloadId   String?  // dedup key: download ID or 'pro:userId:soundId:YYYY-MM' or 'order:itemId'
  amountRp     Int      // nominal Rupiah yang didapat
  poolPercent  Int      @default(25) // % pool yang dipakai saat itu
  earnedAt     DateTime @default(now())

  wallet CreatorWallet @relation(fields: [walletId], references: [id])

  @@unique([walletId, downloadId]) // prevents duplicate earnings from race conditions
  @@index([walletId])
  @@map("creator_earnings")
}

model WithdrawalRequest {
  id        String   @id @default(uuid())
  walletId  String
  amountRp  Int
  status    String   @default("PENDING") // "PENDING" | "PAID" | "REJECTED"
  bankName  String?
  accountNo String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet CreatorWallet @relation(fields: [walletId], references: [id])

  @@map("withdrawal_requests")
}

// ─── Ratings & Reviews ───────────────────────────────────

model Rating {
  id         String   @id @default(uuid())
  userId     String
  audioAssetId String
  score      Int      // 1–5
  reviewText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  audioAsset AudioAsset @relation(fields: [audioAssetId], references: [id])

  @@unique([userId, audioAssetId])
  @@map("ratings")
}

// ─── Wishlists ───────────────────────────────────────────

model Wishlist {
  id            String   @id @default(uuid())
  userId        String
  audioAssetId  String
  createdAt     DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  audioAsset AudioAsset @relation(fields: [audioAssetId], references: [id])

  @@unique([userId, audioAssetId])
  @@map("wishlists")
}

// User notifications

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([type])
  @@map("notifications")
}
