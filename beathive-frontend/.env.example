# Arsonus Frontend Environment Example
# Copy this file to .env.local, then fill the public frontend values.

# Backend API URL used by the frontend.
NEXT_PUBLIC_API_URL=

# Midtrans public client key. Use the buyer's own Midtrans account.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# Midtrans environment flag: true for production, false for sandbox.
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=